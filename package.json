{
  "name": "chat-manager-api",
  "description": "Simple api sample in Node",
  "version": "1.2.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --ignore-watch node_modules ./index.ts",
    "prebuild": "rimraf dist",
    "build": "npm run prebuild && tsc",
    "start": "node dist/index.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "jest --config jest.unit.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:unit:coverage": "jest --config jest.unit.config.js --coverage --coverageDirectory coverage/unit",
    "test:integration:coverage": "jest --config jest.integration.config.js --coverage --coverageDirectory coverage/integration",
    "test:e2e:coverage": "jest --config jest.e2e.config.js --coverage --coverageDirectory coverage/e2e",
    "test:coverage": "npm run test:unit:coverage && npm run test:integration:coverage && npm run test:e2e:coverage",
    "docker:prebuild": "rm -rf dist",
    "docker:build": "npm run docker:prebuild && tsc",
    "docker:start": "node dist/index.js"
  },
  "author": "Google LLC",
  "license": "Apache-2.0",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "ws": "^8.18.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.12",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
